# ============================================================
# イベント管理エージェント 環境変数設定テンプレート
# このファイルを .env にコピーして実際の値を入力してください
# ============================================================

# --- Notion ---
NOTION_API_KEY=secret_ntn_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# --- Gemini ---
# 無料枠あり: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# --- Doorkeeper ---
# Doorkeeper APIはトークン不要でも利用可能（レート制限あり）
DOORKEEPER_API_TOKEN=your_doorkeeper_token_here

# --- connpass ---
# APIキー登録: https://connpass.com/api/
CONNPASS_API_KEY=your_connpass_api_key_here

# --- ユーザー興味・関心キーワード（カンマ区切り） ---
INTEREST_KEYWORDS=DX,生成AI,AI,LLM,機械学習,Web3,ブロックチェーン,スタートアップ,プロダクト,SaaS

# --- 収集設定 ---
# イベント収集日数（今日から何日後まで）
COLLECT_DAYS_AHEAD=30
# connpass 1回のAPI取得件数
CONNPASS_COUNT=100
# AI判定スコアの閾値 (0.0〜1.0)
AI_SCORE_THRESHOLD=0.6
